<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- TrollStore private entitlements for EAAccessory bypass -->

    <!-- Bypass MFi authentication check for external accessories -->
    <key>com.apple.private.external-accessory.no-mfi</key>
    <true/>

    <!-- Allow listing accessories without a matching protocol string -->
    <key>com.apple.private.externalaccessory.withoutprotocol</key>
    <true/>

    <!-- General private Bluetooth access for TrollStore apps -->
    <key>com.apple.private.bluetooth</key>
    <true/>

    <!-- Bluetooth - allow connecting to remote devices by UUID -->
    <key>com.apple.bluetooth.allow-le-remote-uuid</key>
    <true/>
</dict>
</plist>
